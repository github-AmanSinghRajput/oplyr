# ─────────────────────────────────────────────────────────────
# Oplyr environment configuration
# Copy this file to `.env`. Every value is OPTIONAL (sensible defaults apply)
# except CLOUD_DATABASE_URL, which is required only when running the cloud
# control plane with APP_ENV=production. Validated in
# apps/api/src/config/env.ts and apps/cloud-api/src/config/env.ts.
# NEVER commit real secrets — keep placeholders in this file.
# ─────────────────────────────────────────────────────────────

# ── Local runtime API (apps/api) ─────────────────────────────
APP_ENV=development                 # development | test | production
API_PORT=8787
API_HOST=127.0.0.1
CORS_ORIGIN=http://localhost:5173   # must be a valid absolute URL
RUNTIME_DATABASE_PATH=.local/runtime.db
LOCAL_API_AUTH_TOKEN=               # secret: token the web/desktop client must send (blank = no auth)
ALLOWED_WORKSPACE_ROOTS=            # comma-separated absolute paths the AI may work in (defaults to $HOME)

# ── Coding agent CLIs (binary name or absolute path on $PATH) ─
CODEX_COMMAND=codex
CLAUDE_COMMAND=claude
GEMINI_COMMAND=gemini               # Gemini provider is coming soon
CODEX_MODEL=                        # optional Codex model override
CODEX_REASONING_EFFORT=             # minimal | low | medium | high | xhigh
GEMINI_API_KEY=                     # secret — only needed if you use the Gemini agent
# Advanced Gemini/Google auth (rarely needed):
# GOOGLE_API_KEY=  GOOGLE_GENAI_USE_VERTEXAI=  GOOGLE_APPLICATION_CREDENTIALS=  GOOGLE_CLOUD_PROJECT=

# ── Speech / STT (native Parakeet on Apple Silicon, no fallback) ─
VOICE_LOCALE=en-US
TRANSCRIPTION_LANGUAGE_CODE=en
# SPEECH_MODEL_VERSION=v3            # Parakeet model version the native oplyr-stt binary loads
# OPLYR_STT_BINARY=                  # override path to the native binary (auto-detected when blank)

# ── Local path overrides (normally auto-set by the desktop app) ─
# OPLYR_USER_DATA_DIR=   OPLYR_LOCAL_MODELS_DIR=   OPLYR_SCRIPT_ROOT=

# ── Advanced integrations (not needed for local bring-up) ────
QUEUE_PROVIDER=inline               # none | inline | redis
EMAIL_PROVIDER=none                 # none | resend | sendgrid
VECTOR_PROVIDER=none                # none | postgres | provider
RAG_PROVIDER=none                   # none | postgres
OCR_PROVIDER=none                   # none | textract | vision

# ── Web frontend (apps/web, Vite build-time) ─────────────────
VITE_API_BASE_URL=http://127.0.0.1:8787
VITE_LOCAL_API_AUTH_TOKEN=          # secret: must match LOCAL_API_AUTH_TOKEN if auth is on

# ── Desktop shell (apps/desktop, Electron) — usually left unset ─
# ELECTRON_API_BASE_URL=   ELECTRON_RENDERER_URL=   ELECTRON_OPEN_DEVTOOLS=false

# ── Cloud control plane (apps/cloud-api) ─────────────────────
CLOUD_API_PORT=8788
CLOUD_API_HOST=127.0.0.1
CLOUD_ALLOWED_ORIGIN=http://localhost:3000   # must be a valid absolute URL
CLOUD_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/oplyr_cloud   # secret; REQUIRED when APP_ENV=production
CLOUD_DATABASE_SSL=false
CLOUD_ADMIN_TOKEN=                  # secret
